# Vercel Preview should point at a staging Supabase project, not production.
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key

# Use separate dev/test keys where possible.
ANTHROPIC_API_KEY=your-preview-anthropic-key
GOOGLE_AI_API_KEY=your-preview-google-ai-key

# Keep false/absent while Preview still points at production.
# Set to true only after Preview Supabase variables are isolated.
ALLOW_PREVIEW_MUTATIONS=false
